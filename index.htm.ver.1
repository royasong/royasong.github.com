          pgrep -f webappmanager | while read pid; do     rss=$(grep 'Rss' /proc/$pid/smaps 2>/dev/null | awk '{sum += $2} END {print sum+0}');     pss=$(grep 'Pss' /proc/$pid/smaps 2>/dev/null | awk '{sum += $2} END {print sum+0}');     uss=$(grep -E 'Private_(Clean|Dirty)' /proc/$pid/smaps 2>/dev/null | awk '{sum += $2} END {print sum+0}');          cmd=$(ps -p $pid -o args= | awk '{print $1}' | xargs basename);          printf "%d\t\t%d\t\t%d\t\t%d\t\t%s\n" "$pid" "$rss" "$pss" "$uss" "$cmd"; done
